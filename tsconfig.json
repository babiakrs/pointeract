{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"rootDir": ".",
		"lib": ["ESNext", "DOM"],
	},
	"include": ["src/**/*", "packages/core/tests/**/*", "docs/**/*", "docs/.vitepress/**/*"],
	"exclude": ["node_modules", "dist"]
}
